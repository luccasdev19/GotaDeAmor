# ====== MONGODB URL ======
# Obter em: https://www.mongodb.com/cloud/atlas
# Formato: mongodb+srv://usuario:senha@cluster.mongodb.net/database
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/gota-de-amor?retryWrites=true&w=majority

# ====== SERVER ======
PORT=5000
NODE_ENV=development
# Em produção: NODE_ENV=production (ativa Secure flag no cookie)

# ====== ADMIN AUTHENTICATION ======
# Use credenciais fortes em produção
ADMIN_USER=admin
ADMIN_PASSWORD=sua_senha_super_segura_aqui

# ====== JWT ======
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres
JWT_EXPIRE=7d

# ====== CORS - Adicione seus domínios aqui ======
# Desenvolvimento:
ALLOWED_ORIGINS=http://localhost:3000
# Produção (descomente quando criar domínio):
# ALLOWED_ORIGINS=http://localhost:3000,https://gotadeamor.com,https://www.gotadeamor.com

# ====== EMAIL (NODEMAILER) ======
# Gmail: https://support.google.com/accounts/answer/185833
# Gere "Senha de Aplicativo" em: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_app_password_aqui
EMAIL_FROM=noreply@gotadeamor.com

# ====== PIX (simulado por enquanto) ======
PIX_KEY_CPNJ=00.000.000/0001-00
PIX_HOLDER_NAME=Gota de Amor ONG
