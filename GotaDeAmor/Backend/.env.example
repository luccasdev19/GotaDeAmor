# ====== MONGODB ======
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/gota-de-amor?retryWrites=true&w=majority

# ====== SERVER ======
PORT=5000
NODE_ENV=development

# ====== ADMIN AUTHENTICATION ======
ADMIN_USER=admin
ADMIN_PASSWORD=sua_senha_super_segura_aqui

# ====== JWT ======
JWT_SECRET=sua_chave_jwt_secreta_aqui
JWT_EXPIRE=7d

# ====== EMAIL (NODEMAILER) ======
# Exemplo com Gmail: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_app_password_aqui
EMAIL_FROM=noreply@gotadeamor.com

# ====== PIX (simulado por enquanto) ======
PIX_KEY_CPNJ=00.000.000/0001-00
PIX_HOLDER_NAME=Gota de Amor ONG
